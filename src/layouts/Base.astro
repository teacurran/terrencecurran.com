---
import { EmDashHead, EmDashBodyStart, EmDashBodyEnd } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";

interface Props {
  title: string;
  description?: string;
  page?: any;
}

const { title, description = "Software Engineering & Design", page } = Astro.props;
const pageContext = page ? createPublicPageContext(page) : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {pageContext && <EmDashHead page={pageContext} />}
    <style is:global>
      :root {
        --color-bg: #fafafa;
        --color-text: #1a1a1a;
        --color-text-muted: #666;
        --color-accent: #2563eb;
        --color-border: #e5e5e5;
        --color-card-bg: #fff;
        --max-width: 48rem;
        --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        --font-mono: "SF Mono", "Fira Code", monospace;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --color-bg: #111;
          --color-text: #e5e5e5;
          --color-text-muted: #999;
          --color-accent: #60a5fa;
          --color-border: #333;
          --color-card-bg: #1a1a1a;
        }
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: var(--font-sans);
        color: var(--color-text);
        background: var(--color-bg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: var(--color-accent);
        text-decoration: none;
      }
      a:hover { text-decoration: underline; }

      .site-header {
        border-bottom: 1px solid var(--color-border);
        padding: 1rem 0;
      }
      .site-header .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .site-header .site-name {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--color-text);
      }
      .site-header nav a {
        margin-left: 1.5rem;
        color: var(--color-text-muted);
        font-size: 0.9rem;
      }
      .site-header nav a:hover { color: var(--color-text); }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      main { padding: 2rem 0 4rem; }

      .hero {
        padding: 3rem 0 2rem;
        text-align: center;
      }
      .hero h1 { font-size: 2.5rem; font-weight: 700; }
      .hero .tagline {
        color: var(--color-text-muted);
        font-size: 1.2rem;
        margin-top: 0.5rem;
      }

      section { margin-bottom: 3rem; }
      section h2 {
        font-size: 1.4rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--color-border);
      }

      .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
        gap: 1rem;
      }
      .project-card {
        display: block;
        padding: 1.25rem;
        border: 1px solid var(--color-border);
        border-radius: 0.5rem;
        background: var(--color-card-bg);
        color: var(--color-text);
        transition: border-color 0.15s;
      }
      .project-card:hover {
        border-color: var(--color-accent);
        text-decoration: none;
      }
      .project-card h3 { font-size: 1.1rem; margin-bottom: 0.25rem; }
      .project-card .client {
        font-size: 0.85rem;
        color: var(--color-text-muted);
      }
      .project-card p {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        margin-top: 0.5rem;
      }

      .post-list { list-style: none; }
      .post-list li { border-bottom: 1px solid var(--color-border); }
      .post-list a {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 0.75rem 0;
        color: var(--color-text);
      }
      .post-list a:hover { color: var(--color-accent); text-decoration: none; }
      .post-list time {
        font-size: 0.85rem;
        color: var(--color-text-muted);
        flex-shrink: 0;
        margin-left: 1rem;
      }

      .view-all {
        display: inline-block;
        margin-top: 1rem;
        font-size: 0.9rem;
      }

      /* Article/content pages */
      .article-header { margin-bottom: 2rem; }
      .article-header h1 { font-size: 2rem; line-height: 1.3; }
      .article-meta {
        display: flex;
        gap: 1rem;
        color: var(--color-text-muted);
        font-size: 0.9rem;
        margin-top: 0.5rem;
      }

      .prose h2 { font-size: 1.5rem; margin: 2rem 0 0.75rem; }
      .prose h3 { font-size: 1.25rem; margin: 1.5rem 0 0.5rem; }
      .prose p { margin-bottom: 1rem; }
      .prose ul, .prose ol { margin-bottom: 1rem; padding-left: 1.5rem; }
      .prose li { margin-bottom: 0.25rem; }
      .prose pre {
        background: var(--color-card-bg);
        border: 1px solid var(--color-border);
        border-radius: 0.375rem;
        padding: 1rem;
        overflow-x: auto;
        margin-bottom: 1rem;
        font-family: var(--font-mono);
        font-size: 0.875rem;
      }
      .prose code {
        font-family: var(--font-mono);
        font-size: 0.875em;
        background: var(--color-card-bg);
        padding: 0.15em 0.35em;
        border-radius: 0.25rem;
      }
      .prose pre code { background: none; padding: 0; }
      .prose img {
        max-width: 100%;
        height: auto;
        border-radius: 0.375rem;
        margin: 1rem 0;
      }
      .prose blockquote {
        border-left: 3px solid var(--color-border);
        padding-left: 1rem;
        color: var(--color-text-muted);
        margin-bottom: 1rem;
      }

      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: 2rem 0;
        color: var(--color-text-muted);
        font-size: 0.85rem;
        text-align: center;
      }
    </style>
  </head>
  <body>
    {pageContext && <EmDashBodyStart page={pageContext} />}
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-name">Terrence Curran</a>
        <nav>
          <a href="/work">Work</a>
          <a href="/blog">Blog</a>
          <a href="/about">About</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>© {new Date().getFullYear()} Terrence Curran</p>
      </div>
    </footer>
    {pageContext && <EmDashBodyEnd page={pageContext} />}
  </body>
</html>
