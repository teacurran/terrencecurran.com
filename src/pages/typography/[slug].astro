---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Image from "../../components/Image.astro";
import TypeTester from "../../components/TypeTester";
import Layout from "../../layouts/Base.astro";

const { slug } = Astro.params;
const { entry: typeface } = await getEmDashEntry("typefaces", slug!);

if (!typeface) return Astro.redirect("/404");

const title = String(typeface.data.title);
const year = typeface.data.year ? String(typeface.data.year) : null;
const summary = typeface.data.summary ? String(typeface.data.summary) : null;
const githubUrl = typeface.data.github_url ? String(typeface.data.github_url) : null;
const downloadUrl = typeface.data.download_url ? String(typeface.data.download_url) : null;
const fontUrl = typeface.data.font_file ? String(typeface.data.font_file) : undefined;
---

<Layout title={`${title} — Typography — Terrence Curran`} description={summary ?? `${title} typeface by Terrence Curran`}>
  <article class="typeface-detail">
    <header class="article-header">
      <h1>{title}</h1>
      <div class="article-meta">
        {year && <span>{year}</span>}
        <span>Terrence Curran</span>
      </div>
    </header>

    {summary && (
      <p class="typeface-summary">{summary}</p>
    )}

    {fontUrl && (
      <section class="typeface-section">
        <h2>Type Tester</h2>
        <TypeTester client:load fontUrl={fontUrl} fontName={title} />
      </section>
    )}

    {fontUrl && (
      <section class="typeface-section">
        <h2>Specimen</h2>
        <div class="specimen-block">
          <style>{`
            @font-face {
              font-family: "specimen-${slug}";
              src: url("${fontUrl}") format("woff2");
              font-display: swap;
            }
          `}</style>
          <div class="specimen-alphabet" style={`font-family: "specimen-${slug}", serif;`}>
            <p class="specimen-upper">ABCDEFGHIJKLMNOPQRSTUVWXYZ</p>
            <p class="specimen-lower">abcdefghijklmnopqrstuvwxyz</p>
            <p class="specimen-numbers">0123456789</p>
            <p class="specimen-symbols">!@#$%^&*(),.?:;</p>
          </div>
        </div>
      </section>
    )}

    {Array.isArray(typeface.data.content) && typeface.data.content.length > 0 && (
      <section class="typeface-section">
        <div class="prose">
          <PortableText value={typeface.data.content} components={{ type: { image: Image } }} />
        </div>
      </section>
    )}

    <section class="typeface-section typeface-links">
      {downloadUrl && (
        <a href={downloadUrl} class="typeface-link-btn" target="_blank" rel="noopener">
          Download font files
        </a>
      )}
      {githubUrl && (
        <a href={githubUrl} class="typeface-link-btn typeface-link-secondary" target="_blank" rel="noopener">
          View source on GitHub
        </a>
      )}
    </section>

    <a href="/typography" class="back-link">← All typefaces</a>
  </article>
</Layout>

<style>
  .typeface-detail {
    max-width: var(--max-width);
  }

  .typeface-summary {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .typeface-section {
    margin-bottom: 3rem;
  }
  .typeface-section h2 {
    font-size: 1.2rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-weight: 500;
  }

  /* Type Tester styles */
  :global(.type-tester) {
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }
  :global(.type-tester-controls) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: var(--color-card-bg);
    border-bottom: 1px solid var(--color-border);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  :global(.type-tester-size) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  :global(.type-tester-size input[type="range"]) {
    width: 10rem;
    accent-color: var(--color-accent);
  }
  :global(.type-tester-reset) {
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    padding: 0.25rem 0.75rem;
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 0.8rem;
  }
  :global(.type-tester-reset:hover) {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }
  :global(.type-tester-input) {
    padding: 2rem 1.5rem;
    min-height: 8rem;
    outline: none;
    word-break: break-word;
    transition: opacity 0.3s;
  }

  /* Specimen styles */
  .specimen-block {
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 2rem 1.5rem;
    background: var(--color-card-bg);
  }
  .specimen-alphabet p {
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
  }
  .specimen-alphabet p:last-child {
    margin-bottom: 0;
  }
  .specimen-upper {
    font-size: 2.5rem;
    line-height: 1.3;
  }
  .specimen-lower {
    font-size: 2.5rem;
    line-height: 1.3;
  }
  .specimen-numbers {
    font-size: 2rem;
    line-height: 1.3;
  }
  .specimen-symbols {
    font-size: 1.5rem;
    line-height: 1.3;
    color: var(--color-text-muted);
  }

  /* Links */
  .typeface-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .typeface-link-btn {
    display: inline-block;
    padding: 0.6rem 1.25rem;
    border-radius: 0.375rem;
    font-size: 0.9rem;
    font-weight: 500;
    background: var(--color-accent);
    color: #fff;
    transition: opacity 0.15s;
  }
  .typeface-link-btn:hover {
    opacity: 0.85;
    text-decoration: none;
  }
  .typeface-link-secondary {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }
  .typeface-link-secondary:hover {
    border-color: var(--color-accent);
  }

  .back-link {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
  .back-link:hover {
    color: var(--color-accent);
  }
</style>
