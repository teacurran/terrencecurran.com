{
  "version": "1",
  "collections": [
    {
      "slug": "posts",
      "label": "Blog Posts",
      "labelSingular": "Blog Post",
      "urlPattern": "/blog/{slug}",
      "supports": ["drafts", "revisions", "search", "seo"],
      "fields": [
        { "slug": "title", "label": "Title", "type": "string", "required": true },
        { "slug": "slug", "label": "Slug", "type": "slug", "required": true },
        { "slug": "excerpt", "label": "Excerpt", "type": "text" },
        { "slug": "content", "label": "Content", "type": "portableText", "required": true },
        { "slug": "featured_image", "label": "Featured Image", "type": "image" },
        { "slug": "date", "label": "Date", "type": "datetime", "required": true }
      ]
    },
    {
      "slug": "projects",
      "label": "Projects",
      "labelSingular": "Project",
      "urlPattern": "/work/{slug}",
      "supports": ["drafts", "revisions", "search", "seo"],
      "fields": [
        { "slug": "title", "label": "Title", "type": "string", "required": true },
        { "slug": "slug", "label": "Slug", "type": "slug", "required": true },
        { "slug": "client", "label": "Client", "type": "string" },
        { "slug": "year", "label": "Year", "type": "string" },
        { "slug": "summary", "label": "Summary", "type": "text", "required": true },
        { "slug": "content", "label": "Content", "type": "portableText" },
        { "slug": "featured_image", "label": "Featured Image", "type": "image" },
        { "slug": "project_url", "label": "Project URL", "type": "string" },
        { "slug": "sort_order", "label": "Sort Order", "type": "number" }
      ]
    },
    {
      "slug": "pages",
      "label": "Pages",
      "labelSingular": "Page",
      "urlPattern": "/{slug}",
      "supports": ["drafts", "revisions", "search", "seo"],
      "fields": [
        { "slug": "title", "label": "Title", "type": "string", "required": true },
        { "slug": "slug", "label": "Slug", "type": "slug", "required": true },
        { "slug": "content", "label": "Content", "type": "portableText", "required": true }
      ]
    }
  ],
  "taxonomies": [
    {
      "name": "categories",
      "label": "Categories",
      "hierarchical": true,
      "collections": ["posts", "projects"]
    },
    {
      "name": "tags",
      "label": "Tags",
      "hierarchical": false,
      "collections": ["posts"]
    }
  ],
  "menus": [
    {
      "name": "main",
      "label": "Main Navigation",
      "items": [
        { "type": "custom", "label": "Work", "url": "/work" },
        { "type": "custom", "label": "Blog", "url": "/blog" },
        { "type": "custom", "label": "About", "url": "/about" },
        { "type": "custom", "label": "Contact", "url": "/contact" }
      ]
    }
  ],
  "settings": {
    "site_title": "Terrence Curran",
    "site_description": "Software Engineering & Design",
    "site_url": "https://terrencecurran.com"
  }
}
